# 钉钉 SSO 配置
# 从钉钉开放平台获取这些值：https://open.dingtalk.com/

DINGTALK_APP_ID=YOUR_APP_ID
DINGTALK_AGENT_ID=YOUR_AGENT_ID
DINGTALK_CLIENT_ID=YOUR_CLIENT_ID
DINGTALK_CLIENT_SECRET=YOUR_CLIENT_SECRET
DINGTALK_MENTION_CATEGORY_IDS=
NODEBB_BEARER_ALLOWED_IPS=0.0.0.0/0
NODEBB_BEARER_ALLOWED_ROUTES=POST:/api/v3/topics,POST:/api/skills/*

# 钉钉群机器人日报推送（可选）
# 开启后会在每日定时发送社区统计日报到钉钉群
DINGTALK_DAILY_REPORT_ENABLED=false
DINGTALK_DAILY_REPORT_WEBHOOK=
DINGTALK_DAILY_REPORT_SECRET=
DINGTALK_DAILY_REPORT_CRON=0 5 9 * * *
DINGTALK_DAILY_REPORT_TZ=Asia/Shanghai

# API 文章每日自动投递（可选）
ARTICLE_AUTO_PUBLISH_ENABLED=false
ARTICLE_AUTO_PUBLISH_API_BASE_URL=http://10.1.132.21:8001
ARTICLE_AUTO_PUBLISH_CID=
ARTICLE_AUTO_PUBLISH_UID=1
ARTICLE_AUTO_PUBLISH_CRON=0 15 8 * * *
ARTICLE_AUTO_PUBLISH_TZ=Asia/Shanghai
ARTICLE_AUTO_PUBLISH_LOOKBACK_DAYS=1
ARTICLE_AUTO_PUBLISH_PAGE_SIZE=100
ARTICLE_AUTO_PUBLISH_MAX_ARTICLES=100
ARTICLE_AUTO_PUBLISH_MAX_TITLE_LENGTH=30
ARTICLE_AUTO_PUBLISH_DIMENSION=
ARTICLE_AUTO_PUBLISH_SOURCE_IDS=
ARTICLE_AUTO_PUBLISH_KEYWORD=
ARTICLE_AUTO_PUBLISH_TAG_PREFIX=
ARTICLE_AUTO_PUBLISH_INCLUDE_SOURCE_LINK=true

# 微信公众号文章每日自动投递（可选）
# 开启后会在每天 07:00 抓取指定公众号最近 24 小时文章，写入指定分类；未指定 CID 时会自动创建分类。
WECHAT_AUTO_PUBLISH_ENABLED=false
WECHAT_AUTO_PUBLISH_CRON=0 0 7 * * *
WECHAT_AUTO_PUBLISH_TZ=Asia/Shanghai
WECHAT_AUTO_PUBLISH_CID=
WECHAT_AUTO_PUBLISH_CATEGORY_NAME=公众号精选
WECHAT_AUTO_PUBLISH_PARENT_CID=0
WECHAT_AUTO_PUBLISH_UID=1
WECHAT_AUTO_PUBLISH_EXCEL_PATH=docs/account.csv
# CSV/XLSX 优先，读取“账号名称”和“分类”两列；文件不存在时才回退到下方手工配置。
# 简单写法：公众号A,公众号B
# JSON 写法：[{"name":"公众号A","category":"舆情监控"},{"name":"公众号B","category":"前沿认知"}]
WECHAT_AUTO_PUBLISH_ACCOUNTS=
WECHAT_AUTO_PUBLISH_TASK_API_BASE=http://223.93.145.203:31588
WECHAT_AUTO_PUBLISH_TASK_POLL_INTERVAL_MS=10000
WECHAT_AUTO_PUBLISH_TASK_MAX_POLL_ATTEMPTS=60
WECHAT_AUTO_PUBLISH_RESPECT_EXCEL_HOURS=false
WECHAT_AUTO_PUBLISH_MAX_ARTICLES=50
WECHAT_AUTO_PUBLISH_TIMEOUT_MS=15000

# Category page hot-topic module.
# Set to a category ID to show the top 10 topics by viewcount + postcount on that category page.
NODEBB_HOT_TOPICS_CATEGORY_CID=

# Skills gateway (external query + posting)
SKILLS_GATEWAY_ENABLED=false
SKILLS_ALLOWED_IPS=127.0.0.1,::1
SKILLS_SIGNING_SECRET=
SKILLS_SIGNATURE_TTL_SECONDS=300
SKILLS_NONCE_TTL_SECONDS=300
SKILLS_RATE_LIMIT_PER_MINUTE=60
SKILLS_MAX_BODY_BYTES=65536
SKILLS_REQUIRE_ISSUED_TOKENS=true
SKILLS_TOKEN_REQUIRE_DINGTALK_SSO=true
SKILLS_ENFORCE_SCOPES=false
SKILLS_REQUIRE_EXTERNAL_ACTOR=true
SKILLS_REQUIRE_DINGTALK_AUTH=false
SKILLS_DINGTALK_ALLOWED_IDS=
# JSON object, key is sha256(token), value is comma separated scopes
# Example: {"d41d8cd98f00b204e9800998ecf8427e":"post:read,post:write"}
SKILLS_SCOPE_POLICY_JSON={}
